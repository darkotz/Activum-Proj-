<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="PRG1_MAUI_ERP_Activum.View.CustomersPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Kunder"
             BackgroundColor="#F5F7FA">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label
            Text="Kunder"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="#1F2937"
            HorizontalOptions="Center"/>
        <CollectionView x:Name="CustomersCollection"
                        SelectionMode="Single"
                        VerticalOptions="FillAndExpand">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame 
                        CornerRadius="15"
                        Padding="15"
                        Margin="5"
                        BackgroundColor="White"
                        HasShadow="True">

                        <VerticalStackLayout Spacing="5">
                            <Label 
                                Text="{Binding FirstName}" 
                                FontSize="18" 
                                FontAttributes="Bold"
                                TextColor="#111827"/>

                            <Label 
                                Text="{Binding Email}" 
                                FontSize="14" 
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Frame CornerRadius="15" Padding="10" BackgroundColor="White" HasShadow="True">
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">

                <Button 
                    Text="Lägga till"
                    Clicked="OnAddCustomerClicked"
                    BackgroundColor="#3B82F6"
                    TextColor="White"
                    CornerRadius="10"/>

                <Button 
                    Text="Ta bort"
                    Clicked="OnDeleteCustomerClicked"
                    BackgroundColor="#EF4444"
                    TextColor="White"
                    CornerRadius="10"/>

                <Button 
                    Text="Visa försäkringar"
                    Clicked="OnShowInsurancesClicked"
                    BackgroundColor="#10B981"
                    TextColor="White"
                    CornerRadius="10"/>

            </HorizontalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>